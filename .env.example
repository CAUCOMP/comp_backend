# Database Configuration
DB_URL=jdbc:mysql://localhost:3306/your_database_name
DB_USERNAME=your_database_username
DB_PASSWORD=your_database_password

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD는 선택적입니다 (로컬 개발 환경에서는 비워두면 비밀번호 없이 접속)
# AWS ElastiCache 등 프로덕션 환경에서 비밀번호가 설정된 경우에만 입력하세요
REDIS_PASSWORD=

# JWT Configuration
# 생성 방법: openssl rand -base64 32
JWT_SECRET=your-jwt-secret-key-min-256-bits-use-openssl-rand-base64-32
JWT_ACCESS_TOKEN_VALIDITY=10800000
JWT_REFRESH_TOKEN_VALIDITY=1209600000

# Server Configuration
SERVER_PORT=8080

